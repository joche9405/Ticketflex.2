package com.tu_paquete.ticketflex.Model;

import org.springframework.data.annotation.Id;
import org.springframework.data.mongodb.core.mapping.DBRef;
import org.springframework.data.mongodb.core.mapping.Field;
import org.springframework.data.mongodb.core.mapping.Document;
import org.springframework.data.mongodb.core.mapping.ReadOnlyProperty;
import org.springframework.data.mongodb.core.mapping.Unwrapped;

import java.util.Collection;
import java.util.Collections;

import org.springframework.security.core.GrantedAuthority;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.userdetails.UserDetails;

@Document(collection = "usuarios")
public class Usuario implements UserDetails {

    @Id
    private String id; // MongoDB usa ObjectId por defecto

    @Field("nombre")
    private String nombre;

    @Field("apellido")
    private String apellido;

    @Field("email")
    private String email;

    @Field("telefono")
    private String telefono;

    @Field("direccion")
    private String direccion;

    @Field("password")
    private String password;

    @DBRef
    @Field("rol")
    private Rol rol;

    // Getters y setters

    @Override
    public Collection<? extends GrantedAuthority> getAuthorities() {
        return Collections.singleton(new SimpleGrantedAuthority("ROLE_" + this.rol.getNombreRol()));
    }

    @Override
    public String getUsername() {
        return this.email;
    }

    @Override
    public boolean isAccountNonExpired() {
        return true;
    }

    @Override
    public boolean isAccountNonLocked() {
        return true;
    }

    @Override
    public boolean isCredentialsNonExpired() {
        return true;
    }

    @Override
    public boolean isEnabled() {
        return true;
    }
}
