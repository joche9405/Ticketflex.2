# ===== Configuración Principal =====
server.port=8080
server.address=0.0.0.0
spring.main.allow-bean-definition-overriding=true

# ===== Configuración MongoDB (PRINCIPAL) =====
spring.data.mongodb.uri=mongodb://localhost:27017/ticketflex
spring.data.mongodb.auto-index-creation=true
spring.data.mongodb.auto-create-collections=true

# ===== Desactiva MySQL (si no lo usas) =====
#spring.datasource.url=
#spring.datasource.username=
#spring.datasource.password=
#spring.jpa.hibernate.ddl-auto=none

# ===== Configuración Adicional =====
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
spring.servlet.multipart.enabled=true
# Configuración mínima requerida
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.cache=false # Durante desarrollo