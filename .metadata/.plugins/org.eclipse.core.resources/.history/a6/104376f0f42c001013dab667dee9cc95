            // Crear transacción preliminar
            Transaccion transaccion = new Transaccion();
            transaccion.setBoleto(boleto);
            transaccion.setEstado("PENDIENTE");
            transaccion.setMetodoPago("pagoTotal");
            transaccion.setFecha(LocalDateTime.now());
            transaccionRepository.save(transaccion);

            // Generar formulario de redirección
            String formulario = payUService.generarFormularioRedireccion(boleto);
            return ResponseEntity.ok().body(formulario);

        } else if ("ticketFlex".equalsIgnoreCase(request.getMetodoPago())) {
            // Supongamos 3 cuotas
            BigDecimal cuota = boleto.getPrecioTotal().divide(BigDecimal.valueOf(3), 2, RoundingMode.HALF_UP);
            boleto.setSaldoPendiente(boleto.getPrecioTotal().subtract(cuota));
            boleto.setFechaLimitePago(LocalDate.now().plusMonths(3));
            boletoRepository.save(boleto);

            Transaccion transaccion = new Transaccion();
            transaccion.setBoleto(boleto);
            transaccion.setEstadoPago("EXITOSA"); // primera cuota pagada internamente
            transaccion.setMetodoPago("ticketFlex");
            transaccion.setFecha(LocalDateTime.now());
            transaccion.setMontoPagado(cuota);
            transaccion.setSaldoRestante(boleto.getSaldoPendiente());
            transaccionRepository.save(transaccion);

            return ResponseEntity.ok("Pago inicial con TicketFlex registrado. Saldo restante: $" + boleto.getSaldoPendiente());
        }

        return ResponseEntity.badRequest().body("Método de pago no válido");
    }
}

